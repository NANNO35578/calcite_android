<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Notes" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Everforest 主色（柔和自然绿） -->
        <item name="colorPrimary">#A7C080</item>
        <item name="colorPrimaryVariant">#8DA574</item>
        <item name="colorOnPrimary">#2D353A</item>

        <!-- 辅助色（暖灰） -->
        <item name="colorSecondary">#D3C6AA</item>
        <item name="colorSecondaryVariant">#B7AD96</item>
        <item name="colorOnSecondary">#2D353A</item>

        <!-- 状态栏颜色（Everforest 深绿，不刺眼） -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>

        <!-- 状态栏文字自动适配深色/浅色 -->
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
    </style>
</resources>